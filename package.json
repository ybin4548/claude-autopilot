{
  "name": "claude-auto-pilot",
  "version": "1.0.0",
  "description": "Fully automated development orchestrator — from plan to PR with zero human intervention",
  "type": "module",
  "bin": {
    "claude-auto-pilot": "dist/cli.js",
    "claude-auto-pilot-mcp": "dist/mcp-server.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli.js",
    "postinstall": "claude-auto-pilot init"
  },
  "keywords": [
    "claude-code",
    "autopilot",
    "automation",
    "ai-agent",
    "orchestrator",
    "mcp"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ybin4548/claude-autopilot.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
